{
  "name": "locsynq",
  "version": "1.0.0",
  "private": true,
  "description": "Offline-first LAN-based bucket sharing platform",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run dev -w apps/backend",
    "dev:frontend": "npm run dev -w apps/frontend",
    "build:shared": "npm run build -w packages/shared",
    "build:backend": "npm run build -w apps/backend",
    "build:frontend": "npm run build -w apps/frontend",
    "build": "npm run build:shared && npm run build:backend && npm run build:frontend",
    "start": "npm run start -w apps/backend",
    "clean": "rimraf apps/*/node_modules packages/*/node_modules node_modules"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.14",
    "concurrently": "^9.1.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3"
  }
}
